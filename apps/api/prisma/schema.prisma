generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GarageAccountStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  STAFF
  MANAGER
  MECHANIC
  ACCOUNTANT
  READ_ONLY
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum BillingCycle {
  PER_JOB
  WEEKLY
  MONTHLY
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

model GarageAccount {
  id                String              @id @default(uuid()) @db.Uuid
  name              String
  slug              String              @unique
  directorOwnerName String              @map("director_owner_name")
  address           String
  contactNumber     String              @map("contact_number")
  phoneNumber       String              @map("phone_number")
  vatNumber         String?             @map("vat_number")
  status            GarageAccountStatus @default(ACTIVE)
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")
  deletedBy         String?             @map("deleted_by") @db.Uuid

  users     User[]
  modules   GarageAccountModule[]
  settings  SettingOption[]
  auditLogs AuditLog[]
  customers       Customer[]
  suppliers       Supplier[]
  garageRoles     GarageRole[]

  @@map("garage_account")
}

model GarageAccountModule {
  id              String   @id @default(uuid()) @db.Uuid
  garageAccountId String   @map("garage_account_id") @db.Uuid
  moduleKey       String   @map("module_key")
  enabled         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  garageAccount GarageAccount @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)

  @@unique([garageAccountId, moduleKey])
  @@map("garage_account_module")
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  garageAccountId String?    @map("garage_account_id") @db.Uuid
  email           String     @unique
  passwordHash         String     @map("password_hash")
  mustChangePassword   Boolean    @default(false) @map("must_change_password")
  displayName          String     @map("display_name")
  role                 UserRole
  garageRoleId    String?    @map("garage_role_id") @db.Uuid
  status          UserStatus @default(ACTIVE)
  themePreference String?    @map("theme_preference")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")
  deletedBy       String?    @map("deleted_by") @db.Uuid

  garageAccount GarageAccount? @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  garageRole    GarageRole?    @relation(fields: [garageRoleId], references: [id], onDelete: SetNull)
  auditLogs     AuditLog[]

  @@map("users")
}

model SettingOption {
  id              String    @id @default(uuid()) @db.Uuid
  garageAccountId String    @map("garage_account_id") @db.Uuid
  optionType      String    @map("option_type")
  label           String
  value           String
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       String?   @map("deleted_by") @db.Uuid

  garageAccount GarageAccount @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)

  @@index([garageAccountId, optionType])
  @@map("setting_option")
}

model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  garageAccountId String?  @map("garage_account_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  action          String
  entityType      String?  @map("entity_type")
  entityId        String?  @map("entity_id")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  garageAccount GarageAccount? @relation(fields: [garageAccountId], references: [id], onDelete: SetNull)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([garageAccountId, createdAt])
  @@map("audit_log")
}

model Customer {
  id                String       @id @default(uuid()) @db.Uuid
  garageAccountId   String       @map("garage_account_id") @db.Uuid
  type              CustomerType
  firstName         String?      @map("first_name")
  lastName          String?      @map("last_name")
  companyName       String?      @map("company_name")
  email             String?
  phone             String?
  addressLine1      String?      @map("address_line1")
  addressLine2      String?      @map("address_line2")
  city              String?
  postcode          String?
  notes             String?
  isAccountCustomer Boolean      @default(false) @map("is_account_customer")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  deletedAt         DateTime?    @map("deleted_at")
  deletedBy         String?      @map("deleted_by") @db.Uuid

  garageAccount GarageAccount          @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  accountTerms  CustomerAccountTerms?
  vehicles      CustomerVehicle[]

  @@index([garageAccountId, type])
  @@index([garageAccountId, deletedAt])
  @@map("customer")
}

model CustomerAccountTerms {
  id               String        @id @default(uuid()) @db.Uuid
  customerId       String        @unique @map("customer_id") @db.Uuid
  paymentTermsDays Int           @default(30) @map("payment_terms_days")
  creditLimit      Decimal?      @map("credit_limit") @db.Decimal(12, 2)
  billingCycle     BillingCycle  @default(PER_JOB) @map("billing_cycle")
  statementDay     Int?          @map("statement_day")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_account_terms")
}

model CustomerVehicle {
  id           String    @id @default(uuid()) @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  registration String
  make         String?
  model        String?
  colour       String?
  year         Int?
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by") @db.Uuid

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([registration])
  @@map("customer_vehicle")
}

model Supplier {
  id              String         @id @default(uuid()) @db.Uuid
  garageAccountId String         @map("garage_account_id") @db.Uuid
  name            String
  email           String?
  phone           String?
  addressLine1    String?        @map("address_line1")
  addressLine2    String?        @map("address_line2")
  city            String?
  postcode        String?
  vatNumber       String?        @map("vat_number")
  notes           String?
  status          SupplierStatus @default(ACTIVE)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  deletedBy       String?        @map("deleted_by") @db.Uuid

  garageAccount GarageAccount @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)

  @@index([garageAccountId, name])
  @@index([garageAccountId, status])
  @@index([garageAccountId, deletedAt])
  @@map("supplier")
}

model GarageRole {
  id              String   @id @default(uuid()) @db.Uuid
  garageAccountId String   @map("garage_account_id") @db.Uuid
  name            String
  slug            String
  isDefault       Boolean  @default(false) @map("is_default")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  garageAccount GarageAccount            @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  permissions   GarageRolePermission[]
  users         User[]

  @@unique([garageAccountId, slug])
  @@index([garageAccountId])
  @@map("garage_role")
}

model GarageRolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  garageRoleId String   @map("garage_role_id") @db.Uuid
  permission   String
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  garageRole GarageRole @relation(fields: [garageRoleId], references: [id], onDelete: Cascade)

  @@unique([garageRoleId, permission])
  @@map("garage_role_permission")
}
