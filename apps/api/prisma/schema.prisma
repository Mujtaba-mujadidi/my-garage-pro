generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GarageAccountStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  STAFF
  MANAGER
  MECHANIC
  ACCOUNTANT
  READ_ONLY
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum BillingCycle {
  PER_JOB
  WEEKLY
  MONTHLY
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum SupplierRefundType {
  CREDIT
  PAYMENT
}

enum SupplierCreditTransactionType {
  REFUND_CREDIT
  APPLIED_PAYMENT
  ADJUSTMENT
}

enum PaymentAccountType {
  BANK
  CASH
}

enum LedgerEntryDirection {
  INCOME
  EXPENSE
}

enum LedgerEntryStatus {
  PENDING
  CHECKED
  POSTED
  VOID
}

enum LedgerSourceModule {
  GENERAL
  TRANSFER
  ADJUSTMENT
  INVOICES
  REPAIR
  BODYWORK
  PARTS
  TYRES
  PCO
}

enum PartStatus {
  ACTIVE
  INACTIVE
}

/// Whether a part applies to any vehicle (universal) or only listed fitment rows.
enum PartFitmentType {
  UNIVERSAL
  VEHICLE_SPECIFIC
}

enum PartMovementType {
  RECEIPT
  SALE
  CONSUMPTION
  RETURN
  ADJUSTMENT
}

enum JobPartUsageStatus {
  ORDERED
  CONSUMED
  RETURNED
  CANCELLED
}

enum JobPartSource {
  STOCK
  ORDERED
}

enum TyreStatus {
  ACTIVE
  INACTIVE
}

enum TyreCondition {
  NEW
  PART_WORN
}

enum TyreMovementType {
  RECEIPT
  SALE
  CONSUMPTION
  RETURN
  ADJUSTMENT
}

enum JobTyreUsageStatus {
  CONSUMED
  RETURNED
}

enum RepairJobStatus {
  NEW
  QUOTE_SENT
  APPROVED
  AWAITING_VEHICLE
  AWAITING_PARTS
  ON_HOLD
  IN_PROGRESS
  TESTING
  READY
  COMPLETED
  CANCELLED
}

enum RepairJobSource {
  CUSTOMER
  INTERNAL
  RENTAL
  WARRANTY
}

enum RepairTaskStatus {
  AVAILABLE
  ASSIGNED
  STARTED
  AWAITING_VEHICLE
  AWAITING_PARTS
  IN_PROGRESS
  ON_HOLD
  TESTING
  COMPLETED
  CANCELLED
}

enum BodyworkJobStatus {
  NEW
  QUOTE_SENT
  APPROVED
  AWAITING_VEHICLE
  AWAITING_PARTS
  ON_HOLD
  IN_PROGRESS
  TESTING
  READY
  COMPLETED
  CANCELLED
}

enum BodyworkJobSource {
  CUSTOMER
  INSURANCE
  INTERNAL
  RENTAL
  WARRANTY
}

enum BodyworkTaskStatus {
  AVAILABLE
  ASSIGNED
  STARTED
  AWAITING_VEHICLE
  AWAITING_PARTS
  IN_PROGRESS
  ON_HOLD
  TESTING
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PART_PAID
  PAID
  CANCELLED
}

enum InvoiceLineType {
  LABOUR
  PARTS
  TYRES
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  CASH
  CHEQUE
  OTHER
}

// Who pays the TfL / centre booking slot fee (Add booking details).
enum PcoBookingSlotPaidBy {
  US
  CUSTOMER
  NA
  TFL_CREDIT
}

// On cancel: what happens to an existing slot fee (Us or Customer paid).
enum PcoSlotFeeDisposition {
  NOT_APPLICABLE
  RETAINED
  REFUND_REQUESTED
}

// Retained TfL credit lifecycle on the cancelled booking.
enum PcoSlotCreditStatus {
  NOT_APPLICABLE
  AVAILABLE
  APPLIED
}

enum PcoJobType {
  RENEWAL
  NEW
  ADMIN
  LOGBOOK_EXPIRING
  RETEST
  RESCHEDULE
}

enum PcoBookingStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PcoPriority {
  LOW
  MEDIUM
  HIGH
}

enum PcoVehicleStatus {
  ACTIVE
  ARCHIVED
}

model GarageAccount {
  id                String              @id @default(uuid()) @db.Uuid
  name              String
  slug              String              @unique
  directorOwnerName String              @map("director_owner_name")
  address           String
  contactNumber     String              @map("contact_number")
  phoneNumber       String              @map("phone_number")
  vatNumber         String?             @map("vat_number")
  status            GarageAccountStatus @default(ACTIVE)
  invoiceNextSeq    Int                 @default(0) @map("invoice_next_seq")
  repairNextSeq     Int                 @default(0) @map("repair_next_seq")
  bodyworkNextSeq   Int                 @default(0) @map("bodywork_next_seq")
  pcoNextSeq        Int                 @default(0) @map("pco_next_seq")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")
  deletedBy         String?             @map("deleted_by") @db.Uuid

  users     User[]
  modules   GarageAccountModule[]
  settings  SettingOption[]
  auditLogs AuditLog[]
  customers        Customer[]
  suppliers        Supplier[]
  paymentAccounts  PaymentAccount[]
  ledgerEntries    LedgerEntry[]
  garageRoles      GarageRole[]
  invoices         Invoice[]
  customerPayments CustomerPayment[]
  repairJobs       RepairJob[]
  bodyworkJobs     BodyworkJob[]
  parts            Part[]
  partMovements    PartMovement[]
  jobPartUsages    JobPartUsage[]
  tyres            Tyre[]
  tyreMovements    TyreMovement[]
  jobTyreUsages            JobTyreUsage[]
  supplierCreditTransactions SupplierCreditTransaction[]
  pcoVehicles              PcoVehicle[]
  pcoBookings              PcoBooking[]

  @@map("garage_account")
}

model GarageAccountModule {
  id              String   @id @default(uuid()) @db.Uuid
  garageAccountId String   @map("garage_account_id") @db.Uuid
  moduleKey       String   @map("module_key")
  enabled         Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  garageAccount GarageAccount @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)

  @@unique([garageAccountId, moduleKey])
  @@map("garage_account_module")
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  garageAccountId String?    @map("garage_account_id") @db.Uuid
  email           String     @unique
  passwordHash         String     @map("password_hash")
  mustChangePassword   Boolean    @default(false) @map("must_change_password")
  displayName          String     @map("display_name")
  role                 UserRole
  garageRoleId    String?    @map("garage_role_id") @db.Uuid
  status          UserStatus @default(ACTIVE)
  themePreference String?    @map("theme_preference")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")
  deletedBy       String?    @map("deleted_by") @db.Uuid

  garageAccount        GarageAccount? @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  garageRole           GarageRole?    @relation(fields: [garageRoleId], references: [id], onDelete: SetNull)
  auditLogs            AuditLog[]
  ledgerEntriesCreated LedgerEntry[]  @relation("LedgerEntryCreatedBy")
  repairJobsCreated    RepairJob[]    @relation("RepairJobCreatedBy")
  repairTasksAssigned  RepairTask[]   @relation("RepairTaskAssignee")
  bodyworkJobsCreated  BodyworkJob[]  @relation("BodyworkJobCreatedBy")
  bodyworkTasksAssigned BodyworkTask[] @relation("BodyworkTaskAssignee")
  partMovementsCreated PartMovement[] @relation("PartMovementCreatedBy")
  jobPartUsagesCreated JobPartUsage[] @relation("JobPartUsageCreatedBy")
  tyreMovementsCreated TyreMovement[] @relation("TyreMovementCreatedBy")
  jobTyreUsagesCreated       JobTyreUsage[]              @relation("JobTyreUsageCreatedBy")
  supplierCreditsCreated     SupplierCreditTransaction[] @relation("SupplierCreditCreatedBy")
  pcoBookingsCreated         PcoBooking[]                @relation("PcoBookingCreatedBy")
  pcoBookingsCompleted       PcoBooking[]                @relation("PcoBookingCompletedBy")
  pcoBookingsCancelled       PcoBooking[]                @relation("PcoBookingCancelledBy")
  pcoPaymentsCreated         PcoBookingPayment[]         @relation("PcoPaymentCreatedBy")

  @@map("users")
}

model SettingOption {
  id              String    @id @default(uuid()) @db.Uuid
  garageAccountId String    @map("garage_account_id") @db.Uuid
  optionType      String    @map("option_type")
  label           String
  value           String
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       String?   @map("deleted_by") @db.Uuid

  garageAccount GarageAccount @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  pcoBookings   PcoBooking[]

  @@index([garageAccountId, optionType])
  @@map("setting_option")
}

model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  garageAccountId String?  @map("garage_account_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  action          String
  entityType      String?  @map("entity_type")
  entityId        String?  @map("entity_id")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  garageAccount GarageAccount? @relation(fields: [garageAccountId], references: [id], onDelete: SetNull)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([garageAccountId, createdAt])
  @@map("audit_log")
}

model Customer {
  id                String       @id @default(uuid()) @db.Uuid
  garageAccountId   String       @map("garage_account_id") @db.Uuid
  type              CustomerType
  firstName         String?      @map("first_name")
  lastName          String?      @map("last_name")
  companyName       String?      @map("company_name")
  email             String?
  phone             String?
  addressLine1      String?      @map("address_line1")
  addressLine2      String?      @map("address_line2")
  city              String?
  postcode          String?
  notes             String?
  isAccountCustomer Boolean      @default(false) @map("is_account_customer")
  chargeVat         Boolean      @default(true) @map("charge_vat")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  deletedAt         DateTime?    @map("deleted_at")
  deletedBy         String?      @map("deleted_by") @db.Uuid

  garageAccount GarageAccount          @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  accountTerms  CustomerAccountTerms?
  vehicles      CustomerVehicle[]
  invoices       Invoice[]
  payments       CustomerPayment[]
  ledgerEntries  LedgerEntry[]
  repairJobs     RepairJob[]
  bodyworkJobs   BodyworkJob[]
  pcoVehicles    PcoVehicle[]

  @@index([garageAccountId, type])
  @@index([garageAccountId, email])
  @@index([garageAccountId, deletedAt])
  @@map("customer")
}

model CustomerAccountTerms {
  id               String        @id @default(uuid()) @db.Uuid
  customerId       String        @unique @map("customer_id") @db.Uuid
  paymentTermsDays Int           @default(30) @map("payment_terms_days")
  creditLimit      Decimal?      @map("credit_limit") @db.Decimal(12, 2)
  billingCycle     BillingCycle  @default(PER_JOB) @map("billing_cycle")
  statementDay     Int?          @map("statement_day")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_account_terms")
}

model CustomerVehicle {
  id           String    @id @default(uuid()) @db.Uuid
  customerId   String    @map("customer_id") @db.Uuid
  registration String
  make         String?
  model        String?
  colour       String?
  year         Int?
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by") @db.Uuid

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([registration])
  @@map("customer_vehicle")
}

model Supplier {
  id              String         @id @default(uuid()) @db.Uuid
  garageAccountId String         @map("garage_account_id") @db.Uuid
  name            String
  email           String?
  phone           String?
  addressLine1    String?        @map("address_line1")
  addressLine2    String?        @map("address_line2")
  city            String?
  postcode        String?
  vatNumber       String?        @map("vat_number")
  notes           String?
  creditBalance   Decimal        @default(0) @map("credit_balance") @db.Decimal(14, 2)
  status          SupplierStatus @default(ACTIVE)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  deletedBy       String?        @map("deleted_by") @db.Uuid

  garageAccount        GarageAccount              @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  parts                Part[]
  tyres                Tyre[]
  jobPartUsages        JobPartUsage[]
  creditTransactions   SupplierCreditTransaction[]

  @@index([garageAccountId, name])
  @@index([garageAccountId, status])
  @@index([garageAccountId, deletedAt])
  @@map("supplier")
}

model SupplierCreditTransaction {
  id              String                        @id @default(uuid()) @db.Uuid
  garageAccountId String                        @map("garage_account_id") @db.Uuid
  supplierId      String                        @map("supplier_id") @db.Uuid
  type            SupplierCreditTransactionType
  amount          Decimal                       @db.Decimal(14, 2)
  balanceAfter    Decimal                       @map("balance_after") @db.Decimal(14, 2)
  jobPartUsageId  String?                       @map("job_part_usage_id") @db.Uuid
  ledgerEntryId   String?                       @map("ledger_entry_id") @db.Uuid
  notes           String?
  createdById     String                        @map("created_by_id") @db.Uuid
  createdAt       DateTime                      @default(now()) @map("created_at")

  garageAccount GarageAccount @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  supplier      Supplier      @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  jobPartUsage  JobPartUsage? @relation(fields: [jobPartUsageId], references: [id], onDelete: SetNull)
  ledgerEntry   LedgerEntry?  @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)
  createdBy     User          @relation("SupplierCreditCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([supplierId, createdAt])
  @@index([garageAccountId])
  @@map("supplier_credit_transaction")
}

model PaymentAccount {
  id              String             @id @default(uuid()) @db.Uuid
  garageAccountId String             @map("garage_account_id") @db.Uuid
  name            String
  type            PaymentAccountType
  openingBalance  Decimal            @default(0) @map("opening_balance") @db.Decimal(14, 2)
  isActive        Boolean            @default(true) @map("is_active")
  sortOrder       Int                @default(0) @map("sort_order")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  deletedAt       DateTime?          @map("deleted_at")
  deletedBy       String?            @map("deleted_by") @db.Uuid

  garageAccount        GarageAccount  @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  ledgerEntries        LedgerEntry[]
  customerPayments     CustomerPayment[]
  jobPartReturnPayments JobPartUsage[] @relation("JobPartReturnPaymentAccount")
  pcoBookingPayments   PcoBookingPayment[]
  pcoSlotPayments      PcoBooking[]        @relation("PcoSlotPaymentAccount")

  @@index([garageAccountId, deletedAt])
  @@map("payment_account")
}

model LedgerEntry {
  id               String               @id @default(uuid()) @db.Uuid
  garageAccountId  String               @map("garage_account_id") @db.Uuid
  paymentAccountId String               @map("payment_account_id") @db.Uuid
  direction        LedgerEntryDirection
  status           LedgerEntryStatus    @default(PENDING)
  sourceModule     LedgerSourceModule   @default(GENERAL) @map("source_module")
  customerId       String?              @map("customer_id") @db.Uuid
  customerPaymentId String?             @unique @map("customer_payment_id") @db.Uuid
  valueDate        DateTime             @map("value_date") @db.Date
  postedAt         DateTime?            @map("posted_at")
  amountNet        Decimal              @map("amount_net") @db.Decimal(14, 2)
  vatAmount        Decimal              @default(0) @map("vat_amount") @db.Decimal(14, 2)
  amountGross      Decimal              @map("amount_gross") @db.Decimal(14, 2)
  category         String?
  supplierId       String?              @map("supplier_id") @db.Uuid
  notes            String?
  reversesEntryId  String?              @unique @map("reverses_entry_id") @db.Uuid
  createdById      String               @map("created_by_id") @db.Uuid
  checkedById      String?              @map("checked_by_id") @db.Uuid
  approvedById     String?              @map("approved_by_id") @db.Uuid
  voidedById       String?              @map("voided_by_id") @db.Uuid
  checkedAt        DateTime?            @map("checked_at")
  voidedAt         DateTime?            @map("voided_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  garageAccount     GarageAccount      @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  paymentAccount    PaymentAccount     @relation(fields: [paymentAccountId], references: [id], onDelete: Restrict)
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerPayment   CustomerPayment?   @relation(fields: [customerPaymentId], references: [id], onDelete: SetNull)
  repairJobId       String?            @map("repair_job_id") @db.Uuid
  repairJob         RepairJob?         @relation(fields: [repairJobId], references: [id], onDelete: SetNull)
  bodyworkJobId     String?            @map("bodywork_job_id") @db.Uuid
  bodyworkJob       BodyworkJob?       @relation(fields: [bodyworkJobId], references: [id], onDelete: SetNull)
  jobPartUsageId    String?            @unique @map("job_part_usage_id") @db.Uuid
  jobPartUsage      JobPartUsage?      @relation(fields: [jobPartUsageId], references: [id], onDelete: SetNull)
  jobTyreUsageId    String?            @unique @map("job_tyre_usage_id") @db.Uuid
  jobTyreUsage      JobTyreUsage?      @relation(fields: [jobTyreUsageId], references: [id], onDelete: SetNull)
  partMovementId    String?            @unique @map("part_movement_id") @db.Uuid
  partMovement      PartMovement?      @relation(fields: [partMovementId], references: [id], onDelete: SetNull)
  tyreMovementId    String?            @unique @map("tyre_movement_id") @db.Uuid
  tyreMovement      TyreMovement?      @relation(fields: [tyreMovementId], references: [id], onDelete: SetNull)
  paymentMethod     PaymentMethod?     @map("payment_method")
  createdBy         User               @relation("LedgerEntryCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  reversesEntry            LedgerEntry?                @relation("LedgerReversal", fields: [reversesEntryId], references: [id], onDelete: SetNull)
  reversedBy               LedgerEntry?                @relation("LedgerReversal")
  supplierCreditTransactions SupplierCreditTransaction[]
  pcoBookingPayment        PcoBookingPayment?
  pcoSlotBooking           PcoBooking?         @relation("PcoSlotLedgerEntry")

  pcoBookingId     String?    @map("pco_booking_id") @db.Uuid
  pcoBooking       PcoBooking? @relation(fields: [pcoBookingId], references: [id], onDelete: SetNull)

  @@index([garageAccountId, status])
  @@index([garageAccountId, valueDate])
  @@index([paymentAccountId, status])
  @@map("ledger_entry")
}

model GarageRole {
  id              String   @id @default(uuid()) @db.Uuid
  garageAccountId String   @map("garage_account_id") @db.Uuid
  name            String
  slug            String
  isDefault       Boolean  @default(false) @map("is_default")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  garageAccount GarageAccount            @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  permissions   GarageRolePermission[]
  users         User[]

  @@unique([garageAccountId, slug])
  @@index([garageAccountId])
  @@map("garage_role")
}

model GarageRolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  garageRoleId String   @map("garage_role_id") @db.Uuid
  permission   String
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  garageRole GarageRole @relation(fields: [garageRoleId], references: [id], onDelete: Cascade)

  @@unique([garageRoleId, permission])
  @@map("garage_role_permission")
}

model Invoice {
  id              String        @id @default(uuid()) @db.Uuid
  garageAccountId String        @map("garage_account_id") @db.Uuid
  customerId      String        @map("customer_id") @db.Uuid
  invoiceNumber   String        @map("invoice_number")
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime?     @map("issue_date") @db.Date
  dueDate         DateTime?     @map("due_date") @db.Date
  amountNet       Decimal       @map("amount_net") @db.Decimal(14, 2)
  vatAmount       Decimal       @default(0) @map("vat_amount") @db.Decimal(14, 2)
  amountGross           Decimal       @map("amount_gross") @db.Decimal(14, 2)
  vehicleRegistration String?       @map("vehicle_registration")
  depositAmount       Decimal       @default(0) @map("deposit_amount") @db.Decimal(14, 2)
  repairJobId         String?       @unique @map("repair_job_id") @db.Uuid
  bodyworkJobId       String?       @unique @map("bodywork_job_id") @db.Uuid
  notes                 String?
  createdById           String        @map("created_by_id") @db.Uuid
  sentAt          DateTime?     @map("sent_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  garageAccount GarageAccount        @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  repairJob     RepairJob?           @relation(fields: [repairJobId], references: [id], onDelete: SetNull)
  bodyworkJob   BodyworkJob?         @relation(fields: [bodyworkJobId], references: [id], onDelete: SetNull)
  lines         InvoiceLine[]
  allocations   PaymentAllocation[]
  partMovements PartMovement[]
  tyreMovements TyreMovement[]

  @@unique([garageAccountId, invoiceNumber])
  @@index([garageAccountId, customerId, status])
  @@index([garageAccountId, status])
  @@map("invoice")
}

model InvoiceLine {
  id             String  @id @default(uuid()) @db.Uuid
  invoiceId      String  @map("invoice_id") @db.Uuid
  lineType       InvoiceLineType @default(PARTS) @map("line_type")
  description    String
  quantity       Decimal         @default(1) @db.Decimal(12, 3)
  unitPriceNet   Decimal @map("unit_price_net") @db.Decimal(14, 2)
  vatRatePercent Decimal @default(0) @map("vat_rate_percent") @db.Decimal(5, 2)
  amountNet      Decimal @map("amount_net") @db.Decimal(14, 2)
  vatAmount      Decimal @default(0) @map("vat_amount") @db.Decimal(14, 2)
  amountGross    Decimal @map("amount_gross") @db.Decimal(14, 2)
  sortOrder      Int     @default(0) @map("sort_order")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line")
}

model CustomerPayment {
  id                String         @id @default(uuid()) @db.Uuid
  garageAccountId   String         @map("garage_account_id") @db.Uuid
  customerId        String         @map("customer_id") @db.Uuid
  paymentAccountId  String         @map("payment_account_id") @db.Uuid
