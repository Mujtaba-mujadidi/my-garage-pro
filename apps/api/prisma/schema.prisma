  cancelledById         String?          @map("cancelled_by_id") @db.Uuid
  rescheduledFromBookingId String?       @unique @map("rescheduled_from_booking_id") @db.Uuid
  rescheduledToBookingId   String?       @unique @map("rescheduled_to_booking_id") @db.Uuid
  notes                 String?
  createdById           String           @map("created_by_id") @db.Uuid
  completedAt           DateTime?        @map("completed_at")
  completedById         String?          @map("completed_by_id") @db.Uuid
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  garageAccount   GarageAccount      @relation(fields: [garageAccountId], references: [id], onDelete: Cascade)
  vehicle         PcoVehicle         @relation(fields: [pcoVehicleId], references: [id], onDelete: Restrict)
  bookingCentre   SettingOption?     @relation(fields: [bookingCentreId], references: [id], onDelete: SetNull)
  slotPaymentAccount PaymentAccount? @relation("PcoSlotPaymentAccount", fields: [slotPaymentAccountId], references: [id], onDelete: SetNull)
  slotLedgerEntry    LedgerEntry?    @relation("PcoSlotLedgerEntry", fields: [slotLedgerEntryId], references: [id], onDelete: SetNull)
  slotCreditSourceBooking PcoBooking? @relation("PcoSlotCreditSource", fields: [slotCreditSourceBookingId], references: [id], onDelete: SetNull)
  slotCreditConsumers   PcoBooking[]  @relation("PcoSlotCreditSource")
  cancelledBy         User?              @relation("PcoBookingCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  rescheduledFromBooking PcoBooking?   @relation("PcoRescheduleFrom", fields: [rescheduledFromBookingId], references: [id], onDelete: SetNull)
  rescheduledFromSuccessor PcoBooking? @relation("PcoRescheduleFrom")
  rescheduledToBooking   PcoBooking?   @relation("PcoRescheduleTo", fields: [rescheduledToBookingId], references: [id], onDelete: SetNull)
  rescheduledToPredecessor PcoBooking? @relation("PcoRescheduleTo")
  createdBy       User               @relation("PcoBookingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  completedBy     User?              @relation("PcoBookingCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  payments        PcoBookingPayment[]
  ledgerEntries   LedgerEntry[]

  @@unique([garageAccountId, bookingNumber])
  @@index([garageAccountId, status])
  @@index([pcoVehicleId])
  @@map("pco_booking")
}

model PcoBookingPayment {
  id               String        @id @default(uuid()) @db.Uuid
  pcoBookingId     String        @map("pco_booking_id") @db.Uuid
  paymentAccountId String        @map("payment_account_id") @db.Uuid
  method           PaymentMethod
  amount           Decimal       @db.Decimal(14, 2)
  valueDate        DateTime      @map("value_date") @db.Date
  ledgerEntryId    String?       @unique @map("ledger_entry_id") @db.Uuid
  createdById      String        @map("created_by_id") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at")

  booking       PcoBooking    @relation(fields: [pcoBookingId], references: [id], onDelete: Cascade)
  paymentAccount PaymentAccount @relation(fields: [paymentAccountId], references: [id], onDelete: Restrict)
  ledgerEntry   LedgerEntry?  @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)
  createdBy     User          @relation("PcoPaymentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([pcoBookingId])
  @@map("pco_booking_payment")
}
