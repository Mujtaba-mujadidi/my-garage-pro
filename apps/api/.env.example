PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:3011

DATABASE_URL=postgresql://mygaragepro:mygaragepro_dev@localhost:5433/mygaragepro

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=12h

# Encrypts sensitive fields at rest (e.g. PCO TfL login passwords). Min 16 chars; use a long random value in production.
FIELD_ENCRYPTION_KEY=local-dev-only-change-me-32chars!

# Seed (pnpm db:seed)
SEED_SUPER_ADMIN_EMAIL=admin@demo.garage
SEED_SUPER_ADMIN_PASSWORD=demo
