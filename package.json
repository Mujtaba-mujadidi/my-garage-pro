{
  "name": "mygaragepro",
  "private": true,
  "version": "0.1.0",
  "description": "Modular garage / business management SaaS",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"pnpm --filter @mygaragepro/web dev\" \"pnpm --filter @mygaragepro/api dev\"",
    "build": "pnpm --filter @mygaragepro/shared build && pnpm --filter @mygaragepro/api build && pnpm --filter @mygaragepro/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @mygaragepro/api db:generate",
    "db:migrate": "pnpm --filter @mygaragepro/api db:migrate",
    "db:migrate:deploy": "pnpm --filter @mygaragepro/api db:migrate:deploy",
    "db:seed": "pnpm --filter @mygaragepro/api db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
